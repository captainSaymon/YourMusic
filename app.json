{
  "expo": {
    "name": "YourMusic",
    "slug": "YourMusic",
    "version": "1.0.0",
    "orientation": "portrait",
    "ico": "./assets/main-icon-white.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/main-icon-white.png",
      "resizeMode": "cover",
      "backgroundColor": "#6600a1"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/main-icon-white.png",
        "backgroundColor": "#6600a1"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_AUDIO",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.YourMusic"
    },
    "web": {
      "favicon": "./assets/main-icon-purple.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ]
  }
}
